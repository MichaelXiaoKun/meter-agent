# Copy to .env for local use, or set these in Railway / your host dashboard.
# Do not commit real secrets.

# --- LLM Provider API Keys ---
# Set the key(s) for whichever provider(s) you want to use.
# At least one is required.

# Anthropic Claude (claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-5, …)
ANTHROPIC_API_KEY=

# OpenAI (gpt-4o, gpt-4o-mini, o3-mini, …)
# OPENAI_API_KEY=

# Google Gemini via OpenAI-compatible endpoint (gemini-2.5-pro, gemini-2.0-flash, …)
# GEMINI_API_KEY=

# PostgreSQL (Railway usually injects this when the DB is linked)
DATABASE_URL=

# Auth0 (names use _PROD when BLUEBOT_ENV=PROD)
BLUEBOT_ENV=PROD
AUTH0_DOMAIN_PROD=
AUTH0_CLIENT_ID_PROD=
AUTH0_API_AUDIENCE_PROD=
AUTH0_REALM=Username-Password-Authentication

# --- Optional ---
# Orchestrator main chat model. Default: claude-haiku-4-5.
# Any model ID from meter_agent/llm/registry.py MODEL_CATALOG is accepted.
# Examples — Anthropic: claude-sonnet-4-6 | claude-opus-4-5
#            OpenAI:     gpt-4o | gpt-4o-mini | o3-mini
#            Gemini:     gemini-2.5-pro | gemini-2.5-flash | gemini-2.0-flash
# ORCHESTRATOR_MODEL=claude-haiku-4-5
#
# Comma-separated list of model IDs to expose in the UI picker.
# Defaults to all models in MODEL_CATALOG. Mix providers freely.
# ORCHESTRATOR_ALLOWED_MODELS=claude-haiku-4-5,gpt-4o-mini,gemini-2.0-flash
#
# Sub-agent model overrides (same model ID format as above):
# BLUEBOT_ANALYSIS_MODEL=claude-haiku-4-5
# BLUEBOT_PIPE_CONFIG_MODEL=claude-haiku-4-5
# BLUEBOT_METER_STATUS_MODEL=claude-haiku-4-5
# Max parallel /api chat turns (run_turn) per server process — extras wait in a FIFO queue.
# Default 2. Set to 1 to fully serialize turns and reduce Anthropic TPM bursts.
# ORCHESTRATOR_MAX_CONCURRENT_TURNS=2
# Cap LLM↔tool iterations per user message (default 32, clamped 4…128) to prevent runaway loops.
# ORCHESTRATOR_MAX_TOOL_ROUNDS=32
#
# TPM / input budget (run_turn compresses when over target). If ORCHESTRATOR_TPM_GUIDE_TOKENS is unset,
# defaults follow Anthropic Tier-1 ITPM by model: Haiku 4.5 → 50k, Sonnet/Opus 4 → 30k.
# ORCHESTRATOR_TPM_GUIDE_TOKENS=50000
# Fraction of TPM guide for max input tokens before proactive compress. The default is also capped
# by ORCHESTRATOR_TPM_NEXT_CALL_FACTOR so an empty 60s window can run (Haiku 50k / 2.05 → ~24.4k).
# ORCHESTRATOR_TPM_HEADROOM_FRACTION=0.5
# Or set the cap explicitly. If your Anthropic tier supports higher input TPM, raise both this and
# ORCHESTRATOR_TPM_GUIDE_TOKENS together.
# ORCHESTRATOR_MAX_INPUT_TOKENS_TARGET=24390
#
# Before each main stream / compression call, wait until sliding 60s input sum + estimate fits under
# ORCHESTRATOR_TPM_GUIDE_TOKENS * ORCHESTRATOR_TPM_SLIDING_BUDGET_FRACTION (default 1.0).
# ORCHESTRATOR_TPM_NEXT_CALL_FACTOR=2.05   # count_tokens + stream both bill ~same input size
# ORCHESTRATOR_TPM_SLIDING_BUDGET_FRACTION=1.0
# ORCHESTRATOR_TPM_SLIDING_MAX_WAIT_SECONDS=240
#
# GET /api/config includes tpm_sliding_input_tokens_60s — in-process 60s sliding sum of input tokens
# for this orchestrator worker (same Anthropic key). Subprocess sub-agents are not included unless you add reporting.

# Bluebot high-res flow API (default: prod). Override if your stack uses another base URL.
# Flow analysis: max plausible seconds between consecutive samples when online (gap/coverage cap).
# BLUEBOT_MAX_HEALTHY_INTER_ARRIVAL_S=60
# BLUEBOT_GAP_SLACK=1.5
# BLUEBOT_FLOW_HIGH_RES_BASE=https://prod.bluebot.com/flow/v2/high-res/data
# BLUEBOT_METER_STATUS_BASE=https://prod.bluebot.com/flow/v2/status
# Management API base (no trailing /management) — used by pipe-configuration-agent
# and by the orchestrator's get_meter_profile tool (GET /management/v1/device?serialNumber=...).
# BLUEBOT_MANAGEMENT_BASE=https://prod.bluebot.com
#
# MQTT — pipe-configuration-agent defaults: mqtt://mqtt-prod.bluebot.com:1883 (plain TCP, client_id=lens_<uuid>)
# Override only if you need a different broker (defaults are built into pipe-configuration-agent):
# BLUEBOT_MQTT_HOST=mqtt-prod.bluebot.com
# BLUEBOT_MQTT_PORT=1883
# BLUEBOT_MQTT_USE_TLS=false
# BLUEBOT_MQTT_USERNAME=
# BLUEBOT_MQTT_PASSWORD=
# Optional tuning (defaults shown)
# BLUEBOT_PIPE_SET_WAIT_DEFAULT_SEC=20
# BLUEBOT_PIPE_SET_WAIT_SLOW_SEC=60
# BLUEBOT_PIPE_SET_WAIT_50W_SEC=20
# BLUEBOT_MQTT_VERIFY_PAUSE_SEC=2
# BLUEBOT_MQTT_KEEPALIVE=60
# SSA-only publishes (set_transducer_angle_only): wait after single ssa message
# BLUEBOT_SSA_ONLY_WAIT_SEC=20
# BLUEBOT_SSA_ONLY_WAIT_SLOW_SEC=60
# If you use TLS (e.g. port 8883), optional dev-only: disable cert verification (not recommended)
# BLUEBOT_MQTT_TLS_INSECURE=false
# MQTT step tracing: set on the orchestrator host; child inherits stderr so [bluebot-mqtt] lines
# show in the uvicorn terminal (not in the chat transcript).
# BLUEBOT_MQTT_DEBUG=1
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.up.railway.app
# FRONTEND_DIST=
# Flow-analysis PNGs: omit for default, or use an absolute path, or a path relative to the
# meter_agent repo root (folder that contains orchestrator/ and data-processing-agent/), e.g. data-processing-agent/plots.
#
# Railway — persist plots across deploys (#1):
#   1. Add a Volume to your service and mount it (e.g. /data/plots).
#   2. Set PLOTS_DIR to that mount path, e.g. PLOTS_DIR=/data/plots
#   3. Same value must be used by the API and the data-processing-agent subprocess (inherited env).
#   4. Prefer a single replica unless the volume is shared across replicas; otherwise GET /api/plots
#      can 404 when a request hits an instance that did not create the file.
# PLOTS_DIR=
# PLOTS_DIR=/data/plots
#
# Analysis JSON bundles: same pattern as PLOTS_DIR. Default is
# data-processing-agent/analyses/ (gitignored). Use a persistent mount path
# on cloud deployments so analysis_*.json survives redeploys.
# BLUEBOT_ANALYSES_DIR=
# BLUEBOT_ANALYSES_DIR=/data/analyses
# LOGO_PATH=
# PG_POOL_MAX=10
# display_range timezone: IANA name (e.g. America/New_York), "local" for host TZ, or UTC (default).
# Cloud runtimes are often UTC unless you set TZ — use an explicit IANA name when you need a region.
# DISPLAY_TZ=local
# DISPLAY_TZ=America/New_York
#
# Flow analysis: shorter reports = fewer tokens in chat history.
# Subprocess (data-processing-agent) — cap each assistant message (default 3072):
# BLUEBOT_ANALYSIS_MAX_OUTPUT_TOKENS=2048
# Orchestrator — hard cap on Markdown report characters stored in tool result (default 10000; 0 = no cap):
# BLUEBOT_FLOW_REPORT_MAX_CHARS=6000
# Low-quality processor: max merged intervals in tool JSON (default 120; longest stretches kept if capped).
# BLUEBOT_LOW_QUALITY_MAX_INTERVALS=120
#
# --- Baseline-quality guardrails (see processors/baseline_quality.py) ---
# Refusal thresholds for the (future) today-vs-historical baseline feature.
# Defaults are deliberately strict so the system refuses to answer when data is thin.
# BLUEBOT_BASELINE_MIN_DAYS=5
# BLUEBOT_BASELINE_MIN_WEEKDAY_DAYS=3
# BLUEBOT_BASELINE_MAX_DAY_GAP_RATIO=0.15
# BLUEBOT_BASELINE_MAX_DAY_LOWQ_RATIO=0.20
# BLUEBOT_BASELINE_MAD_Z=3.5
# BLUEBOT_BASELINE_MIN_DAY_FRACTION=0.20
# BLUEBOT_BASELINE_MAX_TODAY_MISSING=0.25
# BLUEBOT_BASELINE_MIN_POST_CHANGE_DAYS=7
# BLUEBOT_BASELINE_CUSUM_Z=2.0

# --- Platform (Railway sets PORT; do not set locally unless needed) ---
# PORT=8080

# --- SQLite only (if you are NOT using DATABASE_URL) ---
# BLUEBOT_CONV_DB=
