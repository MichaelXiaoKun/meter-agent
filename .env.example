# Copy to .env for local use, or set these in Railway / your host dashboard.
# Do not commit real secrets.

# --- Required ---
ANTHROPIC_API_KEY=

# PostgreSQL (Railway usually injects this when the DB is linked)
DATABASE_URL=

# Auth0 (names use _PROD when BLUEBOT_ENV=PROD)
BLUEBOT_ENV=PROD
AUTH0_DOMAIN_PROD=
AUTH0_CLIENT_ID_PROD=
AUTH0_API_AUDIENCE_PROD=
AUTH0_REALM=Username-Password-Authentication

# --- Optional ---
# Bluebot high-res flow API (default: prod). Override if your stack uses another base URL.
# BLUEBOT_FLOW_HIGH_RES_BASE=https://prod.bluebot.com/flow/v2/high-res/data
# BLUEBOT_METER_STATUS_BASE=https://prod.bluebot.com/flow/v2/status
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.up.railway.app
# FRONTEND_DIST=
# Flow-analysis PNGs: omit for default, or use an absolute path, or a path relative to the
# repo root (folder that contains orchestrator/ and data-processing-agent/), e.g. data-processing-agent/plots.
# PLOTS_DIR=
# PLOTS_DIR=/app/data-processing-agent/plots
# Railway: keep 1 replica unless PLOTS_DIR is on a shared volume — each replica has its own disk.
# LOGO_PATH=
# PG_POOL_MAX=10
# display_range timezone: IANA name (e.g. America/New_York), "local" for host TZ, or UTC (default).
# Cloud runtimes are often UTC unless you set TZ — use an explicit IANA name when you need a region.
# DISPLAY_TZ=local
# DISPLAY_TZ=America/New_York

# --- Platform (Railway sets PORT; do not set locally unless needed) ---
# PORT=8080

# --- SQLite only (if you are NOT using DATABASE_URL) ---
# BLUEBOT_CONV_DB=
