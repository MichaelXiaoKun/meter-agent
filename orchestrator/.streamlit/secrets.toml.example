# Copy this file to secrets.toml for local use, or paste values into the
# Streamlit Cloud "Secrets" panel (App settings → Secrets).

# Anthropic API key (required)
ANTHROPIC_API_KEY = ""

# Auth0 configuration — select environment (PROD, DEV, etc.)
BLUEBOT_ENV = "PROD"

# Auth0 credentials for the selected environment
AUTH0_DOMAIN_PROD      = ""
AUTH0_CLIENT_ID_PROD   = ""
AUTH0_API_AUDIENCE_PROD = ""

# Shared across all environments
AUTH0_REALM = "Username-Password-Authentication"

# Optional: for local dev without Auth0, you can set BLUEBOT_TOKEN directly
# and comment out the Auth0 vars — the login gate will be bypassed if
# auth.login_gate() detects a valid token already in the environment.
# BLUEBOT_TOKEN = "your-bluebot-api-token-here"

# Persistent conversation storage (recommended for Streamlit Cloud).
# Without this, conversation history is lost on every redeploy.
# Use a free Supabase project: https://supabase.com → Settings → Database → Connection string (URI mode)
# DATABASE_URL = "postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
