# Vite — copy to ``frontend/.env`` for local dev (or set in CI / host).
# https://vitejs.dev/guide/env-and-mode.html
#
# Forgot / reset email is in-app (``#/forget-pass``) and uses ``POST /api/auth/forgot-password``
# (orchestrator → Auth0 ``/dbconnections/change_password``). Same Auth0 app as login.

# Local dev proxy targets. By default Vite sends all /api traffic to the
# combined/admin backend on :8000. Set VITE_SALES_API_TARGET when running a
# separate sales host on :8001.
# VITE_ADMIN_API_TARGET=http://127.0.0.1:8000
# VITE_SALES_API_TARGET=http://127.0.0.1:8001

# Built SPA API bases. Optional. When unset (default), the SPA calls /api on
# its own origin, which is what combined-mode deploys and reverse-proxied split
# deploys want.
#
# Set both to absolute URLs to deploy the SPA against two backend hosts directly:
# VITE_ADMIN_API_BASE=https://admin.example.com/api
# VITE_SALES_API_BASE=https://sales.example.com/api
